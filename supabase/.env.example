# Supabase Edge Function Environment Variables
# These need to be set in the Supabase Dashboard under Project Settings > Edge Functions > Manage secrets

# Paystack API Keys (Required for payment verification)
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# Note: To set these in Supabase, run:
# supabase secrets set PAYSTACK_SECRET_KEY=your_actual_secret_key
# 
# Or set them in the Supabase Dashboard:
# 1. Go to your project dashboard
# 2. Navigate to Project Settings > Edge Functions
# 3. Click "Manage secrets"
# 4. Add PAYSTACK_SECRET_KEY with your actual Paystack secret key
